# ─────────────────────────────────────────────
# Telegram
# ─────────────────────────────────────────────
# @BotFather → /newbot
TELEGRAM_TOKEN=123456789:AA...tu_token_aqui

# Id numérico (no el @username). Varios: 111,222
# Consíguelo con @userinfobot o @getidsbot
ALLOWED_USER_IDS=123456789

# Nombre que aparece en los mensajes del bot
TARGET_NAME=Roxy

# ─────────────────────────────────────────────
# PC objetivo (el que quieres encender/apagar)
# ─────────────────────────────────────────────
# MAC de la interfaz ethernet (ip link / ethtool)
ROXY_MAC=aa:bb:cc:dd:ee:ff

# Broadcast de tu LAN, p. ej. 192.168.1.255
# Si el bot está en un VPS con port-forward UDP 9: tu IP pública
ROXY_BROADCAST=192.168.1.255
ROXY_WOL_PORT=9

# Host/IP para SSH de /off y /status
# - Misma LAN: 192.168.1.50
# - Tailscale: 100.x.y.z o hostname MagicDNS
ROXY_HOST=192.168.1.50
ROXY_SSH_USER=tu_usuario
ROXY_SSH_PORT=22

# Clave privada en el HOST DEL BOT (deja vacío para usar la default de ssh)
ROXY_SSH_KEY=/home/tu_usuario/.ssh/roxy_power_bot

# Comando remoto de apagado (debe ser NOPASSWD en sudoers del PC objetivo)
ROXY_SSH_POWEROFF_CMD=sudo /sbin/poweroff

LOG_LEVEL=INFO
